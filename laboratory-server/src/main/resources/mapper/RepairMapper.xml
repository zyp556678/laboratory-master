<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.laboratory.mapper.RepairMapper">

    <select id="getAll" parameterType="com.laboratory.model.dto.repair.RepairQueryDto" resultType="com.laboratory.model.vo.repair.RepairVo">
        SELECT
            dr.*,
            d.device_name
        FROM
            lab_device_repair dr
                LEFT JOIN lab_device d ON dr.device_id = d.id
        WHERE
            dr.is_deleted = 0
          AND d.is_deleted = 0
        <if test="deviceId != null and deviceId != 0">
            AND dr.device_id = #{deviceId}
        </if>
        <if test="status != null and status != 0">
            AND dr.status = #{status}
        </if>
        <if test="labId != null and labId != 0">
            AND d.lab_id = #{labId}
        </if>

        order by dr.update_time desc
    </select>
</mapper>
